CREATE SCHEMA IF NOT EXISTS public;

-- =====================================================================
-- ЯРУС 0: СПРАВОЧНИКИ (не имеют внешних зависимостей)
-- =====================================================================

CREATE TABLE public.job_position (
    id          integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name        varchar(100) NOT NULL UNIQUE,
    description text
);
COMMENT ON TABLE  public.job_position           IS 'Справочник должностей сотрудников агентства';
COMMENT ON COLUMN public.job_position.name      IS 'Наименование должности (директор, SMM-менеджер, SEO-специалист и т.п.)';

CREATE TABLE public.service_type (
    id          integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name        varchar(100) NOT NULL UNIQUE,
    code        varchar(20)  NOT NULL UNIQUE,
    description text
);
COMMENT ON TABLE  public.service_type      IS 'Справочник типов рекламных услуг (SMM, SEO, таргетинг и т.п.)';
COMMENT ON COLUMN public.service_type.code IS 'Внутренний короткий код услуги для отчётности';

CREATE TABLE public.kpi_type (
    id          integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name        varchar(100) NOT NULL UNIQUE,
    unit        varchar(20),
    description text
);
COMMENT ON TABLE  public.kpi_type      IS 'Справочник типов KPI (показы, охват, клики, конверсии, CTR и т.п.)';
COMMENT ON COLUMN public.kpi_type.unit IS 'Единица измерения KPI (шт, %, руб и т.п.)';

CREATE TABLE public.campaign_status (
    id          integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name        varchar(50)  NOT NULL UNIQUE,
    sort_order  smallint     NOT NULL DEFAULT 0,
    description text
);
COMMENT ON TABLE  public.campaign_status            IS 'Справочник статусов рекламных кампаний';
COMMENT ON COLUMN public.campaign_status.sort_order IS 'Порядок отображения статуса в интерфейсе';

CREATE TABLE public.currency (
    id     integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    code   char(3)     NOT NULL UNIQUE,
    name   varchar(50) NOT NULL,
    symbol varchar(5)
);
COMMENT ON TABLE  public.currency      IS 'Справочник валют';
COMMENT ON COLUMN public.currency.code IS 'Трёхбуквенный ISO-код валюты (RUB, USD, EUR)';

-- =====================================================================
-- ЯРУС 1: БАЗОВЫЕ ОБЪЕКТЫ (зависят только от справочников)
-- =====================================================================

CREATE TABLE public.client (
    id                integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name              varchar(200) NOT NULL,
    client_type       varchar(20)  NOT NULL,
    inn               varchar(12)  UNIQUE,
    email             varchar(100) UNIQUE,
    address           varchar(255),
    registration_date date         NOT NULL DEFAULT CURRENT_DATE,
    CONSTRAINT client_type_chk CHECK (client_type IN ('legal', 'individual'))
);
COMMENT ON TABLE  public.client             IS 'Клиенты агентства (юр. и физ. лица)';
COMMENT ON COLUMN public.client.inn         IS 'ИНН: 10 цифр для юр. лиц, 12 для ИП';
COMMENT ON COLUMN public.client.client_type IS 'Тип клиента: legal — юр. лицо, individual — физ. лицо';

CREATE TABLE public.employee (
    id              integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    first_name      varchar(50)  NOT NULL,
    middle_name     varchar(50),
    last_name       varchar(50)  NOT NULL,
    job_position_id integer      NOT NULL
        REFERENCES public.job_position(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    email           varchar(100) NOT NULL UNIQUE,
    hire_date       date         NOT NULL DEFAULT CURRENT_DATE,
    is_active       boolean      NOT NULL DEFAULT true,
    username        varchar(50)  NOT NULL UNIQUE
);
COMMENT ON TABLE  public.employee           IS 'Сотрудники рекламного агентства';
COMMENT ON COLUMN public.employee.is_active IS 'true — действующий сотрудник, false — уволен/архив';

CREATE TABLE public.employee_phone (
    id           integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    employee_id  integer     NOT NULL
        REFERENCES public.employee(id) ON UPDATE CASCADE ON DELETE CASCADE,
    phone_number varchar(20) NOT NULL
);
COMMENT ON TABLE public.employee_phone IS 'Телефоны сотрудников (один сотрудник — несколько номеров)';

CREATE TABLE public.service (
    id              integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    service_type_id integer        NOT NULL
        REFERENCES public.service_type(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    name            varchar(150)   NOT NULL,
    base_price      numeric(12, 2) NOT NULL,
    unit            varchar(20)    NOT NULL,
    description     text,
    is_active       boolean        NOT NULL DEFAULT true,
    CONSTRAINT service_base_price_chk CHECK (base_price >= 0)
);
COMMENT ON TABLE  public.service            IS 'Каталог конкретных услуг агентства с базовыми ценами';
COMMENT ON COLUMN public.service.base_price IS 'Базовая цена услуги (точная математика numeric)';

-- =====================================================================
-- ЯРУС 2: СЛОЖНЫЕ ОБЪЕКТЫ (зависят от объектов и справочников)
-- =====================================================================

CREATE TABLE public.advertising_campaign (
    id                      integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name                    varchar(200)   NOT NULL,
    client_id               integer        NOT NULL
        REFERENCES public.client(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    start_date              date           NOT NULL,
    planned_end_date        date           NOT NULL,
    budget                  numeric(14, 2) NOT NULL,
    currency_id             integer        NOT NULL
        REFERENCES public.currency(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    status_id               integer        NOT NULL
        REFERENCES public.campaign_status(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    responsible_employee_id integer        NOT NULL
        REFERENCES public.employee(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    description             text,
    CONSTRAINT advertising_campaign_dates_chk  CHECK (planned_end_date >= start_date),
    CONSTRAINT advertising_campaign_budget_chk CHECK (budget >= 0)
);
COMMENT ON TABLE public.advertising_campaign IS 'Рекламные кампании клиентов';

CREATE TABLE public.creative_material (
    id            integer      GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name          varchar(200) NOT NULL,
    material_type varchar(20)  NOT NULL,
    file_path     varchar(500) NOT NULL,
    file_size_kb  integer      NOT NULL,
    employee_id   integer      NOT NULL
        REFERENCES public.employee(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    created_date  date         NOT NULL DEFAULT CURRENT_DATE,
    is_approved   boolean      NOT NULL DEFAULT false,
    CONSTRAINT creative_material_type_chk CHECK (material_type IN ('text', 'image', 'video', 'banner', 'carousel'))
);
COMMENT ON TABLE  public.creative_material               IS 'Креативные материалы: тексты, изображения, видео, баннеры';
COMMENT ON COLUMN public.creative_material.is_approved   IS 'Утверждён ли материал клиентом (по умолчанию — нет)';
COMMENT ON COLUMN public.creative_material.material_type IS 'Тип материала: text, image, video, banner, carousel';

-- =====================================================================
-- ЯРУС 3: M:N-связь и ДОКУМЕНТЫ (шапки)
-- =====================================================================

CREATE TABLE public.material_campaign (
    id          integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    material_id integer NOT NULL
        REFERENCES public.creative_material(id)    ON UPDATE CASCADE ON DELETE CASCADE,
    campaign_id integer NOT NULL
        REFERENCES public.advertising_campaign(id) ON UPDATE CASCADE ON DELETE CASCADE,
    UNIQUE (material_id, campaign_id)
);
COMMENT ON TABLE public.material_campaign IS 'Привязка креативных материалов к кампаниям (M:N)';

CREATE TABLE public.client_brief (
    id                 integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    brief_number       varchar(20)    NOT NULL UNIQUE,
    creation_date      date           NOT NULL DEFAULT CURRENT_DATE,
    client_id          integer        NOT NULL
        REFERENCES public.client(id)   ON UPDATE CASCADE ON DELETE RESTRICT,
    account_manager_id integer        NOT NULL
        REFERENCES public.employee(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    goal               text           NOT NULL,
    target_audience    text,
    estimated_budget   numeric(14, 2),
    CONSTRAINT client_brief_budget_chk CHECK (estimated_budget IS NULL OR estimated_budget >= 0)
);
COMMENT ON TABLE  public.client_brief                    IS 'Брифы клиентов (шапка)';
COMMENT ON COLUMN public.client_brief.account_manager_id IS 'Сотрудник, ответственный за работу с этим брифом';

CREATE TABLE public.service_contract (
    id              integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    contract_number varchar(20) NOT NULL UNIQUE,
    signing_date    date        NOT NULL DEFAULT CURRENT_DATE,
    client_id       integer     NOT NULL
        REFERENCES public.client(id)   ON UPDATE CASCADE ON DELETE RESTRICT,
    currency_id     integer     NOT NULL
        REFERENCES public.currency(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    start_date      date        NOT NULL,
    end_date        date        NOT NULL,
    CONSTRAINT service_contract_dates_chk CHECK (end_date >= start_date)
);
COMMENT ON TABLE public.service_contract IS 'Договоры на оказание рекламных услуг (шапка)';

CREATE TABLE public.completion_act (
    id                  integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    act_number          varchar(20) NOT NULL UNIQUE,
    act_date            date        NOT NULL DEFAULT CURRENT_DATE,
    service_contract_id integer     NOT NULL
        REFERENCES public.service_contract(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    client_id           integer     NOT NULL
        REFERENCES public.client(id)           ON UPDATE CASCADE ON DELETE RESTRICT,
    currency_id         integer     NOT NULL
        REFERENCES public.currency(id)         ON UPDATE CASCADE ON DELETE RESTRICT
);
COMMENT ON TABLE public.completion_act IS 'Акты выполненных работ (шапка)';

CREATE TABLE public.invoice (
    id                integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    invoice_number    varchar(20) NOT NULL UNIQUE,
    issue_date        date        NOT NULL DEFAULT CURRENT_DATE,
    client_id         integer     NOT NULL
        REFERENCES public.client(id)         ON UPDATE CASCADE ON DELETE RESTRICT,
    currency_id       integer     NOT NULL
        REFERENCES public.currency(id)       ON UPDATE CASCADE ON DELETE RESTRICT,
    completion_act_id integer
        REFERENCES public.completion_act(id) ON UPDATE CASCADE ON DELETE SET NULL,
    due_date          date        NOT NULL,
    CONSTRAINT invoice_due_date_chk CHECK (due_date >= issue_date)
);
COMMENT ON TABLE  public.invoice                   IS 'Счета на оплату';
COMMENT ON COLUMN public.invoice.completion_act_id IS 'Опциональная связь с актом (предоплата может выставляться без акта)';

CREATE TABLE public.campaign_report (
    id                      integer     GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    report_number           varchar(20) NOT NULL UNIQUE,
    report_date             date        NOT NULL DEFAULT CURRENT_DATE,
    advertising_campaign_id integer     NOT NULL
        REFERENCES public.advertising_campaign(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    period_start            date        NOT NULL,
    period_end              date        NOT NULL,
    conclusions             text,
    CONSTRAINT campaign_report_period_chk CHECK (period_end >= period_start)
);
COMMENT ON TABLE public.campaign_report IS 'Отчёты по рекламным кампаниям (шапка)';

-- =====================================================================
-- ЯРУС 4: ПОЗИЦИИ ДОКУМЕНТОВ (детали — каскадно удаляются с шапкой)
-- =====================================================================

CREATE TABLE public.brief_item (
    id               integer  GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    client_brief_id  integer  NOT NULL
        REFERENCES public.client_brief(id) ON UPDATE CASCADE ON DELETE CASCADE,
    service_id       integer  NOT NULL
        REFERENCES public.service(id)      ON UPDATE CASCADE ON DELETE RESTRICT,
    requirements     text,
    desired_deadline date,
    priority         smallint DEFAULT 5,
    UNIQUE (client_brief_id, service_id),
    CONSTRAINT brief_item_priority_chk CHECK (priority IS NULL OR priority BETWEEN 1 AND 10)
);
COMMENT ON TABLE  public.brief_item          IS 'Позиции брифа (услуги в составе одного брифа)';
COMMENT ON COLUMN public.brief_item.priority IS 'Приоритет позиции: 1 (низший) — 10 (высший)';

CREATE TABLE public.contract_item (
    id                  integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    service_contract_id integer        NOT NULL
        REFERENCES public.service_contract(id) ON UPDATE CASCADE ON DELETE CASCADE,
    service_id          integer        NOT NULL
        REFERENCES public.service(id)          ON UPDATE CASCADE ON DELETE RESTRICT,
    volume              numeric(10, 2) NOT NULL,
    unit_price          numeric(12, 2) NOT NULL,
    quantity            integer        NOT NULL DEFAULT 1,
    line_amount         numeric(14, 2) NOT NULL,
    CONSTRAINT contract_item_quantity_chk   CHECK (quantity > 0),
    CONSTRAINT contract_item_unit_price_chk CHECK (unit_price >= 0)
);
COMMENT ON TABLE public.contract_item IS 'Позиции договора (детализация услуг, объёмов и стоимости)';

CREATE TABLE public.act_item (
    id                integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    completion_act_id integer        NOT NULL
        REFERENCES public.completion_act(id) ON UPDATE CASCADE ON DELETE CASCADE,
    service_id        integer        NOT NULL
        REFERENCES public.service(id)        ON UPDATE CASCADE ON DELETE RESTRICT,
    performed_volume  numeric(10, 2) NOT NULL,
    amount            numeric(14, 2) NOT NULL,
    CONSTRAINT act_item_amount_chk CHECK (amount >= 0)
);
COMMENT ON TABLE public.act_item IS 'Позиции акта (детализация фактически выполненных работ)';

CREATE TABLE public.invoice_item (
    id          integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    invoice_id  integer        NOT NULL
        REFERENCES public.invoice(id) ON UPDATE CASCADE ON DELETE CASCADE,
    description varchar(255)   NOT NULL,
    quantity    integer        NOT NULL DEFAULT 1,
    price       numeric(12, 2) NOT NULL,
    amount      numeric(14, 2) NOT NULL,
    CONSTRAINT invoice_item_quantity_chk CHECK (quantity > 0)
);
COMMENT ON TABLE public.invoice_item IS 'Позиции счёта';

CREATE TABLE public.report_kpi (
    id                 integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    campaign_report_id integer        NOT NULL
        REFERENCES public.campaign_report(id) ON UPDATE CASCADE ON DELETE CASCADE,
    kpi_type_id        integer        NOT NULL
        REFERENCES public.kpi_type(id)        ON UPDATE CASCADE ON DELETE RESTRICT,
    value              numeric(14, 2) NOT NULL,
    recorded_date      date           NOT NULL DEFAULT CURRENT_DATE,
    UNIQUE (campaign_report_id, kpi_type_id)
);
COMMENT ON TABLE public.report_kpi IS 'Значения KPI в составе отчёта по кампании';

CREATE TABLE public.payment (
    id             integer        GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    payment_date   date           NOT NULL DEFAULT CURRENT_DATE,
    client_id      integer        NOT NULL
        REFERENCES public.client(id)   ON UPDATE CASCADE ON DELETE RESTRICT,
    amount         numeric(14, 2) NOT NULL,
    currency_id    integer        NOT NULL
        REFERENCES public.currency(id) ON UPDATE CASCADE ON DELETE RESTRICT,
    invoice_id     integer        NOT NULL
        REFERENCES public.invoice(id)  ON UPDATE CASCADE ON DELETE RESTRICT,
    payment_method varchar(30)    NOT NULL,
    is_confirmed   boolean        NOT NULL DEFAULT false,
    CONSTRAINT payment_amount_chk CHECK (amount > 0)
);
COMMENT ON TABLE  public.payment                IS 'Платежи клиентов по выставленным счетам';
COMMENT ON COLUMN public.payment.is_confirmed   IS 'Подтверждён ли факт зачисления денег (по умолчанию — нет)';
COMMENT ON COLUMN public.payment.payment_method IS 'Способ оплаты: наличные, безналичный расчёт, карта и т.п.';
