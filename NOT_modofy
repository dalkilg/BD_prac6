CREATE UNIQUE INDEX public_contract_item_pkey ON public.contract_item (id);

CREATE TABLE public.creative_material (
  id integer NOT NULL DEFAULT nextval('creative_material_id_seq' PRIMARY KEY,
  name varchar(500) NOT NULL,
  material_type varchar(500) NOT NULL,
  file_path varchar(500) NOT NULL,
  file_size_kb integer NOT NULL,
  employee_id integer NOT NULL,
  created_date date NOT NULL,
  is_approved boolean NOT NULL
);

CREATE UNIQUE INDEX public_creative_material_pkey ON public.creative_material (id);

CREATE TABLE public.currency (
  id integer NOT NULL DEFAULT nextval('currency_id_seq' PRIMARY KEY,
  code character NOT NULL UNIQUE,
  name varchar(500) NOT NULL,
  symbol varchar(500)
);

CREATE UNIQUE INDEX public_currency_code_key ON public.currency (code);
CREATE UNIQUE INDEX public_currency_pkey ON public.currency (id);

CREATE TABLE public.employee (
  id integer NOT NULL DEFAULT nextval('employee_id_seq' PRIMARY KEY,
  first_name varchar(500) NOT NULL,
  middle_name varchar(500),
  last_name varchar(500) NOT NULL,
  job_position_id integer NOT NULL,
  email varchar(500) NOT NULL UNIQUE,
  hire_date date NOT NULL,
  is_active boolean NOT NULL,
  username varchar(500) NOT NULL UNIQUE
);

