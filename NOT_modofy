CREATE UNIQUE INDEX public_invoice_item_pkey ON public.invoice_item (id);

CREATE TABLE public.job_position (
  id integer NOT NULL DEFAULT nextval('job_position_id_seq' PRIMARY KEY,
  name varchar(500) NOT NULL UNIQUE,
