CREATE TABLE public.act_item (
  id serial NOT NULL DEFAULT nextval('act_item_id_seq' PRIMARY KEY,
  completion_act_id integer NOT NULL,
  service_id integer NOT NULL,
  performed_volume numeric(10, 2) NOT NULL,
  amount numeric(14, 2) NOT NULL
);

CREATE UNIQUE INDEX public_act_item_pkey ON public.act_item (id);

CREATE TABLE public.advertising_campaign (
  id integer NOT NULL DEFAULT nextval('advertising_campaign_id_seq' PRIMARY KEY,
  name varchar(500) NOT NULL,
  client_id integer NOT NULL,
  start_date date NOT NULL,
  planned_end_date date NOT NULL,
  budget numeric(14, 2) NOT NULL,
  currency_id integer NOT NULL,
  status_id integer NOT NULL,
  responsible_employee_id integer NOT NULL,
  description text
);

CREATE UNIQUE INDEX public_advertising_campaign_pkey ON public.advertising_campaign (id);

CREATE TABLE public.brief_item (
  id serial NOT NULL DEFAULT nextval('brief_item_id_seq' PRIMARY KEY,
  client_brief_id integer NOT NULL,
  service_id integer NOT NULL,
  requirements text,
  desired_deadline date,
  priority smallint
);

CREATE UNIQUE INDEX public_brief_item_client_brief_id_service_id_key ON public.brief_item (client_brief_id, service_id);
CREATE UNIQUE INDEX public_brief_item_pkey ON public.brief_item (id);

CREATE TABLE public.campaign_report (
  id integer NOT NULL DEFAULT nextval('campaign_report_id_seq' PRIMARY KEY,
  report_number varchar(500) NOT NULL UNIQUE,
  report_date date NOT NULL,
  advertising_campaign_id integer NOT NULL,
  period_start date NOT NULL,
  period_end date NOT NULL,
  conclusions text
);

CREATE UNIQUE INDEX public_campaign_report_pkey ON public.campaign_report (id);
CREATE UNIQUE INDEX public_campaign_report_report_number_key ON public.campaign_report (report_number);

CREATE TABLE public.campaign_status (
  id integer NOT NULL DEFAULT nextval('campaign_status_id_seq' PRIMARY KEY,
  name varchar(500) NOT NULL UNIQUE,
  sort_order smallint NOT NULL,
  description text
);

CREATE UNIQUE INDEX public_campaign_status_pkey ON public.campaign_status (id);
CREATE UNIQUE INDEX public_campaign_status_name_key ON public.campaign_status (name);

CREATE TABLE public.client (
  id integer NOT NULL DEFAULT nextval('client_id_seq' PRIMARY KEY,
  name varchar(500) NOT NULL,
  client_type varchar(500) NOT NULL,
  inn varchar(500) UNIQUE,
  email varchar(500) UNIQUE,
  address varchar(500),
  registration_date date NOT NULL
);

CREATE UNIQUE INDEX public_client_pkey ON public.client (id);
CREATE UNIQUE INDEX public_client_email_key ON public.client (email);
CREATE UNIQUE INDEX public_client_inn_key ON public.client (inn);

CREATE TABLE public.client_brief (
  id integer NOT NULL DEFAULT nextval('client_brief_id_seq' PRIMARY KEY,
  brief_number varchar(500) NOT NULL UNIQUE,
  creation_date date NOT NULL,
  client_id integer NOT NULL,
  account_manager_id integer NOT NULL,
  goal text NOT NULL,
  target_audience text,
  estimated_budget numeric(14, 2)
);

CREATE UNIQUE INDEX public_client_brief_brief_number_key ON public.client_brief (brief_number);
CREATE UNIQUE INDEX public_client_brief_pkey ON public.client_brief (id);

CREATE TABLE public.completion_act (
  id integer NOT NULL DEFAULT nextval('completion_act_id_seq' PRIMARY KEY,
  act_number varchar(500) NOT NULL UNIQUE,
  act_date date NOT NULL,
  service_contract_id integer NOT NULL,
  client_id integer NOT NULL,
  currency_id integer NOT NULL
);

CREATE UNIQUE INDEX public_completion_act_pkey ON public.completion_act (id);
CREATE UNIQUE INDEX public_completion_act_act_number_key ON public.completion_act (act_number);

CREATE TABLE public.contract_item (
  id serial NOT NULL DEFAULT nextval('contract_item_id_seq' PRIMARY KEY,
  service_contract_id integer NOT NULL,
  service_id integer NOT NULL,
  volume numeric(10, 2) NOT NULL,
  unit_price numeric(12, 2) NOT NULL,
  quantity integer NOT NULL,
  line_amount numeric(14, 2) NOT NULL
